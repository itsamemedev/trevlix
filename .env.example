# ╔══════════════════════════════════════════════════════════════╗
# ║  TREVLIX v1.0.4 – Umgebungsvariablen Template               ║
# ║  Kopieren mit: cp .env.example .env                          ║
# ║  Dann ALLE Werte anpassen!                                   ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Exchange ────────────────────────────────────────────────────
# Unterstützt: cryptocom | binance | bybit | okx | kucoin
EXCHANGE=cryptocom
API_KEY=dein-api-key
API_SECRET=dein-api-secret

# ── MySQL ────────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=trevlix
# PFLICHT: Sicheres Passwort (min. 16 Zeichen, Groß+Klein+Zahl+Sonderzeichen)!
MYSQL_PASS=ersetze-mich-mit-starkem-passwort
# Root-Passwort (nur für Docker-Setup benötigt)
MYSQL_ROOT_PASS=ersetze-mich-mit-starkem-root-passwort
MYSQL_DB=trevlix

# ── Security (ALLE PFLICHT – niemals Defaults lassen!) ──────────
# Admin-Login-Passwort: Min. 12 Zeichen
ADMIN_PASSWORD=ersetze-mich-admin-passwort

# Dashboard Session Secret
# Generieren: python -c "import secrets; print(secrets.token_hex(32))"
DASHBOARD_SECRET=ersetze-mich-dashboard-secret

# JWT-Secret für API-Tokens
# Generieren: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=ersetze-mich-jwt-secret-32-bytes-hex

# Flask Session Secret Key
# Generieren: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ersetze-mich-flask-secret-key

# Fernet-Key für API-Key-Verschlüsselung in der Datenbank
# Generieren: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=ersetze-mich-fernet-key

# ── Session & CORS ───────────────────────────────────────────────
# Session-Timeout in Minuten
SESSION_TIMEOUT_MIN=30
# Erlaubte Origins (KEIN Wildcard *!)
ALLOWED_ORIGINS=https://deine-domain.com,http://localhost:5000

# ── Trading ───────────────────────────────────────────────────────
# WICHTIG: Erst mit Paper-Trading testen!
PAPER_TRADING=true

# ── Registrierung ─────────────────────────────────────────────────
# Öffentliche Selbst-Registrierung erlauben (false = nur Admin kann User anlegen)
ALLOW_REGISTRATION=false

# ── Optionale Features ────────────────────────────────────────────
# Discord-Webhook für Trade-Benachrichtigungen (leer lassen = deaktiviert)
DISCORD_WEBHOOK=

# Telegram-Bot für Benachrichtigungen (leer lassen = deaktiviert)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# CryptoPanic API v2 für News-Sentiment (leer lassen = News-Feature deaktiviert)
# Token: https://cryptopanic.com/developers/api/
CRYPTOPANIC_TOKEN=
# API-Plan: free | pro | developer (Default: free)
CRYPTOPANIC_API_PLAN=free

# Blocknative für Mempool-Monitoring (leer lassen = deaktiviert, aktuell nicht implementiert)
BLOCKNATIVE_KEY=

# ── Server ────────────────────────────────────────────────────────
PORT=5000

# ── Sprache ──────────────────────────────────────────────────────
# Unterstützt: de | en | es | ru | pt
LANGUAGE=de
