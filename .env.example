# ╔══════════════════════════════════════════════════════════════╗
# ║  TREVLIX v1.3.0 – Umgebungsvariablen Template               ║
# ║  Environment Variables Template                              ║
# ║                                                              ║
# ║  Kopieren mit / Copy with:  cp .env.example .env             ║
# ║  Dann ALLE Werte anpassen! / Then adjust ALL values!         ║
# ║                                                              ║
# ║  Geheimschlüssel generieren: siehe Ende dieser Datei         ║
# ║  Generate secrets: see bottom of this file                   ║
# ╚══════════════════════════════════════════════════════════════╝

# ═══════════════════════════════════════════════════════════════
# EXCHANGE – Primäre Börse / Primary Exchange
# ═══════════════════════════════════════════════════════════════
# Unterstützt / Supported: cryptocom | binance | bybit | okx | kucoin
# Dies ist die primäre Börse, die im Single-Exchange-Modus verwendet wird.
# This is the primary exchange used in single-exchange mode.
EXCHANGE=cryptocom
API_KEY=dein-api-key
API_SECRET=dein-api-secret

# ═══════════════════════════════════════════════════════════════
# MULTI-EXCHANGE – Mehrere Börsen gleichzeitig
#                  Run multiple exchanges simultaneously
# ═══════════════════════════════════════════════════════════════
# Komma-getrennte Liste der aktiven Börsen (leer = nur EXCHANGE oben).
# Comma-separated list of enabled exchanges (empty = only EXCHANGE above).
# Beispiel / Example: EXCHANGES_ENABLED=cryptocom,binance,bybit,okx,kucoin
EXCHANGES_ENABLED=

# ── Crypto.com ─────────────────────────────────────────────────
# API-Zugang: https://crypto.com/exchange/personal/api-management
# API access: https://crypto.com/exchange/personal/api-management
CRYPTOCOM_API_KEY=
CRYPTOCOM_API_SECRET=

# ── Binance ────────────────────────────────────────────────────
# API-Zugang: https://www.binance.com/en/my/settings/api-management
# API access: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Bybit ──────────────────────────────────────────────────────
# API-Zugang: https://www.bybit.com/app/user/api-management
# API access: https://www.bybit.com/app/user/api-management
BYBIT_API_KEY=
BYBIT_API_SECRET=

# ── OKX ────────────────────────────────────────────────────────
# API-Zugang: https://www.okx.com/account/my-api
# API access: https://www.okx.com/account/my-api
# WICHTIG: OKX benötigt eine Passphrase zusätzlich zum API-Key!
# IMPORTANT: OKX requires a passphrase in addition to the API key!
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# ── KuCoin ─────────────────────────────────────────────────────
# API-Zugang: https://www.kucoin.com/account/api
# API access: https://www.kucoin.com/account/api
# WICHTIG: KuCoin benötigt eine Passphrase zusätzlich zum API-Key!
# IMPORTANT: KuCoin requires a passphrase in addition to the API key!
KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_PASSPHRASE=

# ═══════════════════════════════════════════════════════════════
# MYSQL – Datenbank-Verbindung / Database Connection
# ═══════════════════════════════════════════════════════════════
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=trevlix
# PFLICHT: Sicheres Passwort (min. 16 Zeichen, Groß+Klein+Zahl+Sonderzeichen)!
# REQUIRED: Strong password (min. 16 chars, upper+lower+digit+special)!
MYSQL_PASS=ersetze-mich-mit-starkem-passwort
# Root-Passwort (nur für Docker-Setup benötigt)
# Root password (only needed for Docker setup)
MYSQL_ROOT_PASS=ersetze-mich-mit-starkem-root-passwort
MYSQL_DB=trevlix

# ═══════════════════════════════════════════════════════════════
# SECURITY – Sicherheit (ALLE PFLICHT – niemals Defaults lassen!)
#            Security (ALL REQUIRED – never keep defaults!)
# ═══════════════════════════════════════════════════════════════

# Admin-Login-Passwort: Min. 12 Zeichen, Groß+Klein+Zahl+Sonderzeichen
# Admin login password: Min. 12 chars, upper+lower+digit+special
ADMIN_PASSWORD=ersetze-mich-admin-passwort

# Dashboard Session Secret
# Generieren / Generate: python -c "import secrets; print(secrets.token_hex(32))"
DASHBOARD_SECRET=ersetze-mich-dashboard-secret

# JWT-Secret für API-Tokens / JWT secret for API tokens
# Generieren / Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=ersetze-mich-jwt-secret-32-bytes-hex

# Flask Session Secret Key
# Generieren / Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ersetze-mich-flask-secret-key

# Fernet-Key für API-Key-Verschlüsselung in der Datenbank
# Fernet key for API key encryption in the database
# Generieren / Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=ersetze-mich-fernet-key

# ═══════════════════════════════════════════════════════════════
# SESSION & CORS – Sitzung und Zugriffskontrolle
#                  Session and Access Control
# ═══════════════════════════════════════════════════════════════
# Session-Timeout in Minuten / Session timeout in minutes
SESSION_TIMEOUT_MIN=30
# Erlaubte Origins (KEIN Wildcard *!) / Allowed origins (NO wildcard *!)
ALLOWED_ORIGINS=https://deine-domain.com,http://localhost:5000

# ═══════════════════════════════════════════════════════════════
# TRADING – Handelseinstellungen / Trading Settings
# ═══════════════════════════════════════════════════════════════
# WICHTIG: Erst mit Paper-Trading testen!
# IMPORTANT: Test with paper trading first!
PAPER_TRADING=true

# ═══════════════════════════════════════════════════════════════
# AUTO_START – Bot Auto-Start
# ═══════════════════════════════════════════════════════════════
# Wenn aktiviert, startet der Bot automatisch beim Programmstart
# ohne dass sich ein Admin zuerst einloggen muss.
# When enabled, the bot starts automatically on program launch
# without requiring an admin login first.
# Empfohlen: false für Produktion, true nur für überwachte Setups.
# Recommended: false for production, true only for monitored setups.
AUTO_START=false

# ═══════════════════════════════════════════════════════════════
# REGISTRIERUNG – Benutzerregistrierung / User Registration
# ═══════════════════════════════════════════════════════════════
# Öffentliche Selbst-Registrierung erlauben (false = nur Admin kann User anlegen)
# Allow public self-registration (false = only admin can create users)
ALLOW_REGISTRATION=false

# ═══════════════════════════════════════════════════════════════
# BENACHRICHTIGUNGEN – Notifications
# ═══════════════════════════════════════════════════════════════

# Discord-Webhook für Trade-Benachrichtigungen (leer lassen = deaktiviert)
# Discord webhook for trade notifications (leave empty = disabled)
DISCORD_WEBHOOK=

# Telegram-Bot für Benachrichtigungen (leer lassen = deaktiviert)
# Telegram bot for notifications (leave empty = disabled)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ═══════════════════════════════════════════════════════════════
# MARKTDATEN – Externe Datenquellen / External Data Sources
# ═══════════════════════════════════════════════════════════════

# CryptoPanic API v2 für News-Sentiment (leer lassen = News-Feature deaktiviert)
# CryptoPanic API v2 for news sentiment (leave empty = news feature disabled)
# Token: https://cryptopanic.com/developers/api/
CRYPTOPANIC_TOKEN=
# API-Plan / API plan: free | pro | developer (Default: free)
CRYPTOPANIC_API_PLAN=free

# Blocknative für Mempool-Monitoring (leer lassen = deaktiviert, aktuell nicht implementiert)
# Blocknative for mempool monitoring (leave empty = disabled, not yet implemented)
BLOCKNATIVE_KEY=

# ═══════════════════════════════════════════════════════════════
# KI / LLM – Künstliche Intelligenz / AI Integration
# ═══════════════════════════════════════════════════════════════
# Lokale LLM-API (z.B. Ollama: http://localhost:11434/api/chat)
# Oder OpenAI-kompatible API (LM Studio, vLLM, etc.)
# Local LLM API (e.g. Ollama: http://localhost:11434/api/chat)
# Or OpenAI-compatible API (LM Studio, vLLM, etc.)
LLM_ENDPOINT=

# API-Key für die LLM-API (leer lassen für lokale Modelle ohne Auth)
# API key for the LLM API (leave empty for local models without auth)
LLM_API_KEY=

# Modellname (z.B. llama3, mistral, gpt-4o) – abhängig vom Anbieter
# Model name (e.g. llama3, mistral, gpt-4o) – depends on provider
LLM_MODEL=

# Maximale Antwortlänge in Tokens / Maximum response length in tokens
LLM_MAX_TOKENS=2048

# Kreativität der Antworten (0.0 = deterministisch, 1.0 = kreativ)
# Response creativity (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.3

# ═══════════════════════════════════════════════════════════════
# PERFORMANCE – Caching und Leistung / Caching and Performance
# ═══════════════════════════════════════════════════════════════

# Cache-Dauer für technische Indikatoren in Sekunden (Standard: 300 = 5 Min.)
# Cache TTL for technical indicators in seconds (default: 300 = 5 min)
INDICATOR_CACHE_TTL=300

# Cache-Dauer für Marktdaten (Fear/Greed, On-Chain) in Sekunden (Standard: 600 = 10 Min.)
# Cache TTL for market data (Fear/Greed, on-chain) in seconds (default: 600 = 10 min)
MARKET_DATA_CACHE_TTL=600

# ═══════════════════════════════════════════════════════════════
# LOGGING – Protokollierung / Logging
# ═══════════════════════════════════════════════════════════════
# Log-Level / Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Strukturierte JSON-Logs für ELK/Grafana/Loki
# Structured JSON logs for ELK/Grafana/Loki
JSON_LOGS=false
# Farbige Konsolenausgabe (ANSI-Farben)
# Colored console output (ANSI colors)
COLOR_LOGS=true

# ═══════════════════════════════════════════════════════════════
# BACKUP – Datensicherung / Data Backup
# ═══════════════════════════════════════════════════════════════
# Automatisches Datenbank-Backup alle X Stunden (0 = deaktiviert)
# Automatic database backup every X hours (0 = disabled)
BACKUP_INTERVAL_HOURS=24

# Backups aufbewahren für X Tage (ältere werden automatisch gelöscht)
# Keep backups for X days (older ones are automatically deleted)
BACKUP_KEEP_DAYS=7

# ═══════════════════════════════════════════════════════════════
# SERVER – Servereinstellungen / Server Settings
# ═══════════════════════════════════════════════════════════════
PORT=5000

# ═══════════════════════════════════════════════════════════════
# SPRACHE – Internationalisierung / Language
# ═══════════════════════════════════════════════════════════════
# Unterstützt / Supported: de | en | es | ru | pt
LANGUAGE=de

# ═══════════════════════════════════════════════════════════════
# GEHEIMSCHLÜSSEL GENERIEREN / GENERATE SECRETS
# ═══════════════════════════════════════════════════════════════
#
# Alle Befehle unten ausführen und Ergebnisse in die .env eintragen:
# Run all commands below and paste results into your .env:
#
# ENCRYPTION_KEY (Fernet, 44 base64url Zeichen / chars):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# JWT_SECRET (64 hex Zeichen / chars):
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# SECRET_KEY (64 hex Zeichen / chars):
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# DASHBOARD_SECRET (64 hex Zeichen / chars):
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# MYSQL_PASS (sicheres Zufallspasswort / secure random password):
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
#
# MYSQL_ROOT_PASS (sicheres Zufallspasswort / secure random password):
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
#
# ADMIN_PASSWORD (sicheres Zufallspasswort / secure random password):
#   python -c "import secrets; print(secrets.token_urlsafe(16))"
#
# Alle auf einmal generieren / Generate all at once:
#   python -c "
#   import secrets
#   from cryptography.fernet import Fernet
#   print(f'ENCRYPTION_KEY={Fernet.generate_key().decode()}')
#   print(f'JWT_SECRET={secrets.token_hex(32)}')
#   print(f'SECRET_KEY={secrets.token_hex(32)}')
#   print(f'DASHBOARD_SECRET={secrets.token_hex(32)}')
#   print(f'MYSQL_PASS={secrets.token_urlsafe(24)}')
#   print(f'MYSQL_ROOT_PASS={secrets.token_urlsafe(24)}')
#   print(f'ADMIN_PASSWORD={secrets.token_urlsafe(16)}')
#   "
