# ╔══════════════════════════════════════════════════════════════╗
# ║  TREVLIX – .gitignore                                        ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Secrets & Konfiguration ──────────────────────────────────────
.env
.env.*
!.env.example
*.key
*.pem
*.crt
docker/ssl/*.crt
docker/ssl/*.key

# ── Python ───────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.pdb
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/
MANIFEST

# ── Virtual Environments ─────────────────────────────────────────
venv/
.venv/
env/
ENV/
.env/

# ── Logs ─────────────────────────────────────────────────────────
*.log
logs/
*.log.*

# ── Runtime-Daten & Cache ────────────────────────────────────────
data/

# ── Backups & Datenbank ──────────────────────────────────────────
backups/
*.sql.gz
*.dump
*.db
*.sqlite
*.sqlite3

# ── ML-Modelle (zur Laufzeit generiert) ─────────────────────────
models/
*.pkl
*.joblib
*.h5
*.keras
*.pt
*.onnx
*.npy
*.npz
optuna.db

# ── Testing & Coverage ───────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# ── IDE & Editoren ───────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath

# ── OS-spezifisch ────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db

# ── Temporäre Dateien ────────────────────────────────────────────
*.tmp
*.bak
*.orig
*.rej

# ── Node (falls Frontend-Tools genutzt werden) ───────────────────
node_modules/
npm-debug.log*

# ── Docker ───────────────────────────────────────────────────────
# SSL-Zertifikate (nur .gitkeep behalten)
docker/ssl/*
!docker/ssl/.gitkeep
